# Run the governed-memory MCP server in a container.
# Read-only by default — the safe posture. Writes require the explicit
# two-flag opt-in at run time (see ADR-003), never baked into the image.

FROM python:3.12-slim

WORKDIR /app
COPY pyproject.toml ./
COPY src/ ./src/
RUN pip install --no-cache-dir -e ".[mcp]"

# Canonical log + derived index live on a mounted volume so the truth is the
# operator's, not the image's.
VOLUME ["/app/data"]

# Default: read-only stdio server. No socket, no record leaves the container.
ENTRYPOINT ["python", "-m", "governed_memory.mcp_server"]

# To allow writes, run with both flags set explicitly:
#   docker run -e GOVERNED_MEMORY_ENABLE_WRITE=true \
#              -e GOVERNED_MEMORY_REQUIRE_APPROVAL=false ...
